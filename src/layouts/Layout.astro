---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<meta name="description"
			content="Únete a la masterclass de Liliana Oliveri y aprende a recuperar tu centro y claridad mental. Método M.E.T.A para transformación personal sostenible. $5,000 ARS." />
		<meta name="keywords"
			content="masterclass, transformación personal, claridad mental, Liliana Oliveri, psicología, desarrollo personal, método META" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content="Masterclass Transformarte - Recupera tu Centro y Claridad Mental" />
		<meta property="og:description"
			content="Aprende el método M.E.T.A con la psicóloga Liliana Oliveri. Masterclass online para recuperar claridad mental y sostener cambios reales." />

		<script type="module" async
			src="https://static.rocket.new/rocket-web.js?_cfg=https%3A%2F%2Flilianaol5634back.builtwithrocket.new&_be=https%3A%2F%2Fappanalytics.rocket.new&_v=0.1.17"></script>
		<script type="module" defer src="https://static.rocket.new/rocket-shot.js?v=0.0.2"></script>
	</head>
	<body>
		<slot />

		<script>
			// Smooth scrolling for navigation links
			document.querySelectorAll('a[href^="#"]').forEach(anchor => {
				anchor.addEventListener('click', function (e) {
					e.preventDefault();
					const target = document.querySelector(this.getAttribute('href') as string);
					if (target) {
						target.scrollIntoView({
							behavior: 'smooth',
							block: 'start'
						});
					}
				});
			});

			// Add loading states to buttons
			document.querySelectorAll('button, .btn-primary, .btn-register').forEach(button => {
				button.addEventListener('click', function (this: HTMLElement) {
					this.style.opacity = '0.8';
					setTimeout(() => {
						this.style.opacity = '1';
					}, 200);
				});
			});
		</script>
	</body>
</html>
