---
---

<section id="details" class="info-section">
    <div class="container">
        <div class="info-header">
            <h2 class="info-title">Todo lo que necesitas saber sobre la Masterclass</h2>
            <div class="info-divider"></div>
        </div>

        <div class="info-grid">
            <div class="info-card">
                <div class="info-card-header">
                    <img src="/images/img_icon_lime_50.svg" alt="Material incluido"
                        class="info-card-icon">
                    <h3 class="info-card-title">Material incluido</h3>
                </div>
                <div class="info-card-list">
                    <div class="info-card-item">
                        <img src="/images/img_margin_lime_50.svg" alt="Bullet point"
                            class="info-card-bullet">
                        <span class="info-card-text">Acceso a la clase en vivo.</span>
                    </div>
                    <div class="info-card-item">
                        <img src="/images/img_margin_lime_50.svg" alt="Bullet point"
                            class="info-card-bullet">
                        <span class="info-card-text">Guía breve descargable para trabajar durante y después del
                            encuentro.</span>
                    </div>
                    <div class="info-card-item">
                        <img src="/images/img_margin_lime_50.svg" alt="Bullet point"
                            class="info-card-bullet">
                        <span class="info-card-text">Acceso a la grabación por tiempo limitado.</span>
                    </div>
                </div>
            </div>

            <div class="info-card">
                <div class="info-card-header">
                    <img src="/images/img_search.svg" alt="Resultados" class="info-card-icon">
                    <h3 class="info-card-title">Resultados que obtendrás</h3>
                </div>
                <div class="info-card-list">
                    <div class="info-card-item">
                        <img src="/images/img_margin_lime_50.svg" alt="Bullet point"
                            class="info-card-bullet">
                        <span class="info-card-text">Más claridad para decidir y priorizar.</span>
                    </div>
                    <div class="info-card-item">
                        <img src="/images/img_margin_lime_50.svg" alt="Bullet point"
                            class="info-card-bullet">
                        <span class="info-card-text">Un primer orden interno para recuperar tu centro.</span>
                    </div>
                    <div class="info-card-item">
                        <img src="/images/img_margin_lime_50.svg" alt="Bullet point"
                            class="info-card-bullet">
                        <span class="info-card-text">Herramientas para sostener límites y energía sin
                            culpa.</span>
                    </div>
                    <div class="info-card-item">
                        <img src="/images/img_margin_lime_50.svg" alt="Bullet point"
                            class="info-card-bullet">
                        <span class="info-card-text">Un paso concreto y aplicable desde el día siguiente.</span>
                    </div>
                </div>
            </div>

            <div class="info-card">
                <div class="info-card-header">
                    <img src="/images/img_icon_lime_50_24x24.svg" alt="Para quién es"
                        class="info-card-icon">
                    <h3 class="info-card-title">Este encuentro es para vos si:</h3>
                </div>
                <div class="info-card-list">
                    <div class="info-card-item">
                        <img src="/images/img_margin_lime_50.svg" alt="Bullet point"
                            class="info-card-bullet">
                        <span class="info-card-text">Sentís que sostenés mucho y te estás quedando sin
                            resto.</span>
                    </div>
                    <div class="info-card-item">
                        <img src="/images/img_margin_lime_50.svg" alt="Bullet point"
                            class="info-card-bullet">
                        <span class="info-card-text">Te falta norte, foco o dirección personal.</span>
                    </div>
                    <div class="info-card-item">
                        <img src="/images/img_margin_lime_50.svg" alt="Bullet point"
                            class="info-card-bullet">
                        <span class="info-card-text">Querés poner límites sin culpa y sin romper
                            vínculos.</span>
                    </div>
                    <div class="info-card-item">
                        <img src="/images/img_margin_lime_50.svg" alt="Bullet point"
                            class="info-card-bullet">
                        <span class="info-card-text">Necesitás método y proceso, no motivación de un
                            rato.</span>
                    </div>
                </div>
            </div>

            <div class="info-card">
                <div class="info-card-header">
                    <img src="/images/img_icon_24x24.svg" alt="Modalidad online"
                        class="info-card-icon">
                    <h3 class="info-card-title">Modalidad online</h3>
                </div>
                <div class="info-card-list">
                    <div class="info-card-item">
                        <img src="/images/img_margin_lime_50.svg" alt="Bullet point"
                            class="info-card-bullet">
                        <span class="info-card-text">Encuentro por Zoom.</span>
                    </div>
                    <div class="info-card-item">
                        <img src="/images/img_margin_lime_50.svg" alt="Bullet point"
                            class="info-card-bullet">
                        <span class="info-card-text">Espacio de reflexión guiada y bajada práctica para tu vida
                            real.</span>
                    </div>
                    <div class="info-card-item">
                        <img src="/images/img_margin_lime_50.svg" alt="Bullet point"
                            class="info-card-bullet">
                        <span class="info-card-text">Clase grabada.</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
