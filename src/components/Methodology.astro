<section class="methodology-section">
    <div class="container">
        <div class="methodology-content">
            <div class="methodology-header">
                <div class="methodology-badge">Nuestra Metodología</div>
                <h2 class="methodology-title">
                    Presentación del Método<br />M.E.T.A
                </h2>
                <p class="methodology-desc">
                    <span class="highlight">M.E.T.A</span> significa: Enfoque, Transformación
                    y Acción sostenida. Una forma concreta de volver a tu centro,
                    salir del modo reacción y construir cambios que se sostengan.
                </p>
            </div>

            <div class="methodology-cards">
                <div class="method-card">
                    <div class="method-letter">M</div>
                    <h3 class="method-title">Mente clara</h3>
                    <p class="method-desc">
                        Orden interno y claridad mental para decidir con más
                        calma y menos culpa.
                    </p>
                </div>

                <div class="method-card">
                    <div class="method-letter">E</div>
                    <h3 class="method-title">Enfoque</h3>
                    <p class="method-desc">
                        Prioridades, dirección y límites posibles: sin ansiedad,
                        sin vivir apagando incendios.
                    </p>
                </div>

                <div class="method-card">
                    <div class="method-letter">T</div>
                    <h3 class="method-title">Transformación</h3>
                    <p class="method-desc">
                        Cambio real con proceso: hábitos, patrones y una mirada
                        más madura sobre vos.
                    </p>
                </div>

                <div class="method-card">
                    <div class="method-letter">A</div>
                    <h3 class="method-title">Acción sostenible</h3>
                    <p class="method-desc">
                        Bajarlo a tierra con microacciones, bitácora y
                        continuidad para sostener lo que cambiás.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>
