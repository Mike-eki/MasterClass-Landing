---

---

<section class="hero-section flex-col container">
    <div class="hero-content">
        <div class="hero-badge">
            <div class="hero-badge-dot"></div>
            <span class="hero-badge-text">Próximo Encuentro Online</span>
        </div>

        <div class="flex-col gap-48">
            <div class="flex-col">
                <h1 class="hero-title">Programa<br />Quiero Cambiar</h1>
                <p class="hero-subtitle">
                    <strong>Método M.E.T.A:</strong> Mente clara, Enfoque,<br />Transformación, Acción sostenida
                </p>

                <div class="hero-cta">
                    <a href="#register" class="btn-primary"
                        >Regístrate - $5.000 ARS</a
                    >
                    <div class="social-proof">
                        <img
                            src="/images/img_container.png"
                            alt="Avatares de participantes"
                            class="social-proof-avatars"
                        />
                        <span class="social-proof-text"
                            >+200 alumnos inscriptos</span
                        >
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="hero-images">
        <div class="hero-image-stack">
            <img
                src="/images/img_image_border_shadow.png"
                alt="Imagen principal del curso"
                class="hero-image-main"
            />
            <img
                src="/images/img_overlay_blur.png"
                alt="Imagen decorativa"
                class="hero-image-overlay"
            />
        </div>

    </div>
</section>
