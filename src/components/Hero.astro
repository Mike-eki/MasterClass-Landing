---
---

<section class="hero-section flex-col container">
    <div class="hero-content">
        <div class="hero-badge">
            <div class="hero-badge-dot"></div>
            <span class="hero-badge-text">Próximo Encuentro Online</span>
        </div>

        <div class="flex-col gap-48">
            <div class="flex-col">
                <h1 class="hero-title">Masterclass<br>Transformarte:</h1>
                <p class="hero-subtitle">cómo recuperar tu centro y<br>tu claridad mental</p>

                <div class="hero-cta">
                    <a href="#register" class="btn-primary">Regístrate - $5.000 ARS</a>
                    <div class="social-proof">
                        <img src="/images/img_container.png" alt="Avatares de participantes"
                            class="social-proof-avatars">
                        <span class="social-proof-text">+200 alumnos inscriptos</span>
                    </div>
                </div>

                <div class="key-points">
                    <h2 class="key-points-title">3 puntos claves a abordar:</h2>

                    <div class="key-points-grid">
                        <div class="key-point">
                            <img src="/images/img_icon.svg" alt="Icono claridad mental"
                                class="key-point-icon">
                            <h3 class="key-point-title">Claridad mental:</h3>
                            <p class="key-point-desc">bajar el ruido interno para<br>pensar y decidir con calma.
                            </p>
                        </div>

                        <div class="key-point">
                            <img src="/images/img_icon.svg" alt="Icono enfoque" class="key-point-icon">
                            <h3 class="key-point-title">Enfoque y límites:</h3>
                            <p class="key-point-desc">ordenar prioridades y<br>sostener tu energía sin<br>culpa.
                            </p>
                        </div>

                        <div class="key-point">
                            <img src="/images/img_icon.svg" alt="Icono acción" class="key-point-icon">
                            <h3 class="key-point-title">Acción sostenible:</h3>
                            <p class="key-point-desc">llevarlo a lo cotidiano con<br>pasos simples.</p>
                        </div>
                    </div>

                    <div class="solution-box">
                        <h3 class="solution-title">¿Qué solución te brinda esta masterclass?</h3>
                        <p class="solution-desc">Te llevás una hoja de ruta inicial para volver a tu centro:
                            recuperar claridad, ordenar prioridades y empezar a accionar sin exigirte más ni
                            vivir reaccionando a todo.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="hero-images">
        <div class="hero-image-stack">
            <img src="/images/img_image_border_shadow.png" alt="Imagen principal del curso"
                class="hero-image-main">
            <img src="/images/img_overlay_blur.png" alt="Imagen decorativa" class="hero-image-overlay">
        </div>

        <div class="hero-image-row">
            <img src="/images/img_image_border_shadow_292x292.png" alt="Imagen del curso 1"
                class="hero-image-small">
            <img src="/images/img_image_border_shadow_1.png" alt="Imagen del curso 2"
                class="hero-image-small">
        </div>
    </div>
</section>
